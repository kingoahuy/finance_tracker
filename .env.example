# Database file path (default: project_root/my_account_book.db)
# FINANCE_DB_FILE=my_account_book.db

# Monthly budget (yuan)
FINANCE_MONTHLY_BUDGET=2000

# SMTP mail settings (for daily report emails)
FINANCE_MAIL_HOST=smtp.qq.com
FINANCE_MAIL_USER=your_email@qq.com
FINANCE_MAIL_PASS=your_smtp_authorization_code
FINANCE_MAIL_RECEIVERS=your_email@qq.com

# Feishu custom app and long-connection bot
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key
FEISHU_ALLOWED_OPEN_IDS=ou_your_open_id
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_BOOTSTRAP_MODE=false

# Feishu Bitable mirror
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_BITABLE_TABLE_ID=your_bitable_table_id
FEISHU_BOT_ENABLED=true
FEISHU_BITABLE_SYNC_ENABLED=true
FEISHU_AUTO_SYNC=true
FEISHU_BITABLE_TIMEOUT_SECONDS=15

# Reserved for the next delivery phase
FEISHU_DAILY_REPORT_ENABLED=false
FEISHU_DAILY_REPORT_TIME=21:30
FEISHU_LOG_LEVEL=INFO
FEISHU_SYNC_RETRY_LIMIT=5

# Optional AI intent parser. SQLite writes always happen in local Python after validation.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_PARSER_ENABLED=true
AI_PARSER_REQUIRE_CONFIRMATION=true
AI_PARSER_TIMEOUT_SECONDS=15
AI_PARSER_FALLBACK_TO_LOCAL=true
