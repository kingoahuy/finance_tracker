# Database file path (default: project_root/my_account_book.db)
# FINANCE_DB_FILE=my_account_book.db

# Monthly budget (yuan)
FINANCE_MONTHLY_BUDGET=2000

# SMTP mail settings (for daily report emails)
FINANCE_MAIL_HOST=smtp.qq.com
FINANCE_MAIL_USER=your_email@qq.com
FINANCE_MAIL_PASS=your_smtp_authorization_code
FINANCE_MAIL_RECEIVERS=your_email@qq.com