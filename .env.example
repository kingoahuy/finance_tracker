# Database and budget
FINANCE_DB_FILE=my_account_book.db
FINANCE_MONTHLY_BUDGET=2000

# Email settings
FINANCE_MAIL_HOST=smtp.qq.com
FINANCE_MAIL_USER=your_email@example.com
FINANCE_MAIL_PASS=your_smtp_authorization_code
FINANCE_MAIL_RECEIVERS=receiver@example.com

# Feishu bot settings
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_ALLOWED_OPEN_IDS=ou_your_open_id
FEISHU_ENABLE_GROUP=false
FEISHU_DAILY_PUSH_TIME=22:30
